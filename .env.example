# Environment Settings
ENV=production
DEBUG=False

# Security
CORE_API_KEY=your-super-secret-api-key-change-in-production
API_TIMEOUT=30
MAX_RETRIES=3
RATE_LIMIT=100

# GHunt Configuration
GHUNT_ENABLED=True
GHUNT_CREDS_PATH=.ghunt_creds
GHUNT_CACHE_DIR=.ghunt_cache

# Google OAuth (Required for GHunt)
# Get these from GHunt Companion extension
GOOGLE_OAUTH_TOKEN=
GOOGLE_MASTER_TOKEN=
GOOGLE_COOKIES=

# OSINT Sources
GRAVATAR_ENABLED=True
HOLEHE_ENABLED=True
XPOSED_ENABLED=True
INTELBASE_ENABLED=True
INTELBASE_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FILE=kangHunt.log

# Performance
WORKERS=4
ASYNC_WORKERS=10
CACHE_ENABLED=True
CACHE_TTL=3600

# Output
OUTPUT_FORMAT=json
OUTPUT_DIR=./results
